DJANGO_SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=[Your backend link]
# Use either DATABASE_URL (recommended for Supabase) or DB_* fields below.
# Example:
# DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.gnkvkptbaoygqkpyowib.supabase.co:5432/postgres
# DB_NAME=ecommerce_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_SSLMODE=
CORS_ALLOWED_ORIGINS=[Your frontend link]

# Optional: Supabase Storage (S3) for product/review image uploads
# Set USE_SUPABASE_STORAGE=True only after creating S3 access keys in Supabase Storage settings.
USE_SUPABASE_STORAGE=False
SUPABASE_STORAGE_BUCKET=product-images
SUPABASE_S3_ENDPOINT=https://[YOUR-PROJECT-REF].supabase.co/storage/v1/s3
SUPABASE_PUBLIC_BASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY=[S3_ACCESS_KEY_ID]
SUPABASE_S3_SECRET_KEY=[S3_SECRET_ACCESS_KEY]
